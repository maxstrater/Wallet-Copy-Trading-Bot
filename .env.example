POLYMARKET_PK=                  # private key WITHOUT 0x prefix
POLYMARKET_FUNDER=              # your Polymarket wallet address
POLYMARKET_API_KEY=             # generated by setup script
POLYMARKET_API_SECRET=          # generated by setup script
POLYMARKET_API_PASSPHRASE=      # generated by setup script
TELEGRAM_BOT_TOKEN=             # from @BotFather on Telegram
TELEGRAM_CHAT_ID=               # your Telegram chat/channel ID
DRY_RUN=true                    # set to false only when ready to go live
MAX_POSITION_SIZE_USDC=50       # max dollars per copied trade
MAX_PORTFOLIO_EXPOSURE_USDC=500 # total max across all open positions
COPY_RATIO=0.5                  # copy at 50% of target wallet's size
MIN_WALLET_WIN_RATE=0.58        # only copy wallets above this win rate
MIN_WALLET_BETS=30              # only copy wallets with 30+ bets history
MIN_SIGNAL_SCORE=65             # minimum signal score (0-100) to copy a trade
POLL_INTERVAL_SECONDS=30        # how often to check for new trades
